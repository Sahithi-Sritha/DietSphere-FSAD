# ============================================
# FRONTEND ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local to Git (it's in .gitignore)

# --------------------------------------------
# API CONFIGURATION
# --------------------------------------------
# Backend API URL (include /api suffix)
# Local development: http://localhost:8080/api
# Production (Railway): https://your-railway-backend-url.railway.app/api
VITE_API_URL=https://your-railway-backend-url.railway.app/api

# --------------------------------------------
# USAGE INSTRUCTIONS
# --------------------------------------------
# 1. Copy this file: cp .env.example .env.local
# 2. Update VITE_API_URL with your actual backend URL
# 3. For local development, you can omit this file (defaults to http://localhost:8080/api)
# 4. For Vercel deployment, set this in Vercel's environment variables dashboard
